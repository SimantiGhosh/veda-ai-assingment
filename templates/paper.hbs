<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{paper.title}}</title>
    <style>
      :root {
        --ink: #1f1f1f;
        --muted: #5a5a5a;
        --border: #d6d6d6;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "Georgia", "Times New Roman", serif;
        color: var(--ink);
        background: #ffffff;
      }

      .page {
        width: 100%;
        padding: 28px 36px 40px;
      }

      .header {
        text-align: center;
        padding-bottom: 12px;
        border-bottom: 1px solid var(--border);
      }

      .school-name {
        font-size: 18px;
        font-weight: 700;
        margin: 0 0 4px 0;
      }

      .subline {
        font-size: 13px;
        margin: 2px 0;
      }

      .meta-row {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        margin-top: 10px;
      }

      .instructions {
        margin-top: 10px;
        font-size: 12px;
      }

      .student-info {
        margin-top: 12px;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 6px 18px;
        font-size: 12px;
      }

      .line {
        display: inline-block;
        min-width: 160px;
        border-bottom: 1px solid var(--ink);
        transform: translateY(-2px);
      }

      .section {
        margin-top: 18px;
      }

      .section-title {
        text-align: center;
        font-size: 14px;
        font-weight: 700;
        margin: 0 0 8px 0;
      }

      .section-instruction {
        font-size: 12px;
        color: var(--muted);
        margin: 0 0 10px 0;
      }

      .questions {
        margin: 0;
        padding-left: 18px;
        font-size: 12px;
      }

      .question {
        margin: 8px 0;
      }

      .question-line {
        display: flex;
        justify-content: space-between;
        gap: 12px;
      }

      .question-text {
        flex: 1;
      }

      .difficulty {
        text-transform: capitalize;
      }

      .marks {
        white-space: nowrap;
      }

      .options {
        margin: 6px 0 0 16px;
        padding: 0;
        list-style: lower-alpha;
        font-size: 12px;
      }

      .options li {
        margin: 3px 0;
      }

      .footer {
        margin-top: 18px;
        font-size: 12px;
        font-weight: 600;
      }
    </style>
  </head>
  <body>
    <div class="page">
      <header class="header">
        <div class="school-name">
          {{#if config.schoolName}}
            {{config.schoolName}}
          {{else}}
            {{paper.title}}
          {{/if}}
        </div>
        <div class="subline">Subject: {{paper.subject}}</div>
        {{#if config.className}}
          <div class="subline">Class: {{config.className}}</div>
        {{/if}}
        <div class="meta-row">
          <span>
            Time Allowed:
            {{#if config.timeAllowed}}
              {{config.timeAllowed}}
            {{else}}
              --
            {{/if}}
          </span>
          <span>Maximum Marks: {{paper.totalMarks}}</span>
        </div>
        {{#if config.paperInstructions}}
          <div class="instructions">{{config.paperInstructions}}</div>
        {{/if}}
      </header>

      <div class="student-info">
        <div>Name: <span class="line"></span></div>
        <div>Roll Number: <span class="line"></span></div>
        <div>Class: <span class="line"></span></div>
        <div>Section: <span class="line"></span></div>
      </div>

      {{#each paper.sections}}
        <section class="section">
          <div class="section-title">{{title}}</div>
          {{#if instruction}}
            <div class="section-instruction">{{instruction}}</div>
          {{/if}}

          <ol class="questions">
            {{#each questions}}
              <li class="question">
                <div class="question-line">
                  <span class="question-text">
                    <span class="difficulty">[{{difficulty}}]</span> {{text}}
                  </span>
                  <span class="marks">[{{marks}} Marks]</span>
                </div>
                {{#if options}}
                  <ol class="options">
                    {{#each options}}
                      <li>{{this}}</li>
                    {{/each}}
                  </ol>
                {{/if}}
              </li>
            {{/each}}
          </ol>
        </section>
      {{/each}}

      <div class="footer">End of Question Paper</div>
    </div>
  </body>
</html>
